GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DATABASE_URL=
ADMIN_SECRET=

# Copy the Web Bot Widget script from OmniDimension Dashboard > Deploy > Web Bot Widget.
# Recommended: paste the complete generated <script ...></script> value here in Vercel.
NEXT_PUBLIC_OMNIDIM_WIDGET_EMBED_SCRIPT=

# Alternative if your generated widget provides a script URL plus attributes.
NEXT_PUBLIC_OMNIDIM_WIDGET_SCRIPT_URL=
NEXT_PUBLIC_OMNIDIM_WIDGET_AGENT_ID=
NEXT_PUBLIC_OMNIDIM_WIDGET_SECRET_KEY=

# Server-side OmniDimension API integration for dispatching voice calls.
# Never expose OMNIDIM_API_KEY as NEXT_PUBLIC_*.
OMNIDIM_API_KEY=
OMNIDIM_AGENT_ID=
OMNIDIM_BASE_URL=https://backend.omnidim.io/api/v1
